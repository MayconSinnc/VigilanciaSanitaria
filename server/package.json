{
  "name": "vigilancia-sanitaria-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
 
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "fastify": "^4.26.2",
    "@fastify/cors": "^8.4.2",
    "@fastify/jwt": "^6.7.1",
    "@fastify/swagger": "^8.14.1",
    "zod": "^3.22.4",
    "@prisma/client": "^5.13.0",
    "pdfkit": "^0.13.0",
    "pg": "^8.16.3",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.7",
    "eslint": "^9.9.0",
    "@types/node": "^20.11.30",
    "@types/pdfkit": "^0.13.3",
    "@types/pg": "^8.15.5",
    "prisma": "^5.13.0"
  }
}
