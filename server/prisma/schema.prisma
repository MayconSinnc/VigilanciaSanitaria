model AutoColetaAmostraLog {
  id            Int                      @id @default(autoincrement())
  autoId        Int
  usuarioId     Int?
  dataHora      DateTime                 @default(now())
  campo         String
  valorAnterior String?
  valorNovo     String?
  acao          String
