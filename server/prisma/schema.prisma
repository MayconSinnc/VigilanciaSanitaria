model RelatorioInspecaoSanitariaSequence {
  ano     Int @id
  lastSeq Int
}

model RelatorioInspecaoSanitariaDocumento {
  id                   Int                 @id @default(autoincrement())
  ano                  Int
  sequencia            Int
  numeroRelatorio      String              @unique
  status               AutoDocumentoStatus @default(RASCUNHO)
  dados                Json
  estabelecimentoNome  String?
  estabelecimentoCnpj  String?
  dataLavratura        String?
  semEfeitoMotivo      String?
  semEfeitoUsuarioId   Int?
  semEfeitoDataHora    DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdByUsuarioId   Int?
  updatedByUsuarioId   Int?
  createdBy            Usuario?            @relation("RelatorioInspecaoCriadoPor", fields: [createdByUsuarioId], references: [id])
  updatedBy            Usuario?            @relation("RelatorioInspecaoAtualizadoPor", fields: [updatedByUsuarioId], references: [id])
