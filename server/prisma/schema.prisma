}

model RelatorioInspecaoLog {
  id            Int                               @id @default(autoincrement())
  relatorioId   Int
  usuarioId     Int?
  dataHora      DateTime                          @default(now())
  campo         String
  valorAnterior String?
  valorNovo     String?
  acao          String
  dispositivo   String?
  relatorio     RelatorioInspecaoSanitariaDocumento @relation(fields: [relatorioId], references: [id])
  usuario       Usuario?                          @relation(fields: [usuarioId], references: [id])
}

model BaseLegalItemConfig {
  id                    Int      @id @default(autoincrement())
  baseLegalId            String   @unique
  descricaoItem          String?
  palavrasChave          Json?
  sinonimos              Json?
  prazoPadraoDias        Int?
  aplicaAutoIntimacao    Boolean  @default(true)
  descricaoIrregularidade String?
  descricaoProvidencia   String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
